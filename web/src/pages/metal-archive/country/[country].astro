---
// Same slug strategy as genre: country names contain spaces (e.g. "Estados Unidos",
// "Reino Unido"). Slugify to URL-safe string; real value travels as prop.
// Country flag emojis: inline map ported from links_bio/states/metal_archive_state.py.
import { ClientRouter } from 'astro:transitions';
import { getAllCountries, getAlbumsByCountry, slugify } from '../../../lib/db.js';
import AlbumCard from '../../../components/AlbumCard.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import '../../../styles/global.css';

