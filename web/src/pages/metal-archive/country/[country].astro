// slugify is imported from db.ts — single source of truth shared with the pages
// that link here. Imports are available in the prerender chunk.
export function getStaticPaths() {
  const countries = getAllCountries();
  return countries.map((facet) => ({
    params: { country: slugify(facet.value) },
    props: { realCountry: facet.value },
  }));
}

interface Props {
  realCountry: string;
}

const { realCountry } = Astro.props;
// NOT_LIVE applied inside getAlbumsByCountry; derive the count from the same
// list so the header number and the grid agree (comparable to Browse).
const albums = getAlbumsByCountry(realCountry);
const count = albums.length;
const flag = COUNTRY_FLAGS[realCountry] ?? '';

// Chain to Browse with this country pre-applied. Search restores from the exact
// value (e.country === country), so the URL carries the REAL country, not the slug.
const browseHref = `/metal-archive/browse?country=${encodeURIComponent(realCountry)}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{realCountry} — Metal Archive</title>
    <meta name="description" content={`${count} ${count === 1 ? 'album' : 'albumes'} de ${realCountry} en el Metal Archive.`} />
    <ClientRouter />
  </head>
  <body>
    <Navbar />

    <main class="wrap" style="padding-top: 2rem;">
      <header class="facet-hero">
        <h1 class="facet-hero__title">
          {flag && <span aria-hidden="true" style="margin-right: 0.4em;">{flag}</span>}{realCountry}
        </h1>
        <p class="facet-hero__count">
          {count} {count === 1 ? 'album' : 'albumes'}
        </p>
        {albums.length > 0 && (
          <a class="facet-refine" href={browseHref}>Refinar en Explorar →</a>
        )}
      </header>

      {albums.length > 0
        ? <div class="album-grid">
            {albums.map((album) => <AlbumCard album={album} />)}
          </div>
        : <p style="color: var(--text-footer);">No hay albumes de este pais.</p>
      }
    </main>

    <Footer />
  </body>
</html>
