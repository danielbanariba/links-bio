---
// submit.astro — Submit a band to the Metal Archive
// POSTs to /api/metal-archive/submit (FastAPI on port 8001, proxied by host)
import { ClientRouter } from 'astro:transitions';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const GENRES = [
  "Death Metal", "Black Metal", "Thrash Metal", "Doom Metal",
  "Grindcore", "Power Metal", "Heavy Metal", "Melodic Death Metal",
  "Grind/Death Metal", "Punk Rock", "Metalcore", "Progressive Metal",
  "Folk Metal", "Symphonic Metal", "Sludge Metal", "Stoner Metal",
  "Speed Metal", "Brutal Death Metal",
];
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Envia tu banda | Metal Archive</title>
  <meta name="description" content="Envia tu banda o album para revision e inclusion gratuita en el archivo." />
  <ClientRouter />
</head>
<body class="form-page">
  <Navbar />

  <main class="form-page__main">
    <!-- Header -->
    <div class="form-page__header">
      <svg class="form-page__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" />
      </svg>
      <h1 class="form-page__title">Envia tu banda</h1>
      <p class="form-page__subtitle">
        Envia tu banda o album para revision e inclusion gratuita en el archivo.
      </p>
    </div>

    <!-- Form card -->
    <div class="form-card" id="form-card">
      <!-- Success state (hidden by default, shown via JS) -->
      <div class="form-success" id="success-state" style="display:none">
        <span class="form-success__icon">&#10004;</span>
        <h2 class="form-success__title">Banda enviada con exito</h2>
        <p class="form-success__body">
          Revisaremos tu envio y te contactaremos pronto. Mantente atento a tu bandeja de entrada.
        </p>
        <a href="/metal-archive/" class="form-success__back">&#8592; Volver al archivo</a>
      </div>

      <!-- The form -->
      <form id="submit-form" class="form-stack" novalidate>
        <!-- Band name + email -->
        <div class="form-row">
          <div class="form-field">
            <label class="form-label" for="band_name">
              Nombre de la banda <span class="form-label__required">*</span>
            </label>
            <input
              id="band_name" name="band_name" type="text"
              class="form-input" placeholder="ej. Blasfemia" required
            />
          </div>
          <div class="form-field">
            <label class="form-label" for="contact_email">
              Email de contacto <span class="form-label__required">*</span>
            </label>
            <input
              id="contact_email" name="contact_email" type="email"
              class="form-input" placeholder="banda@email.com" required
            />
          </div>
        </div>

        <!-- Genre + Country -->
        <div class="form-row">
          <div class="form-field">
            <label class="form-label" for="genre">
              Genero <span class="form-label__required">*</span>
            </label>
            <select id="genre" name="genre" class="form-select" required>
              <option value="">Elige un genero</option>
              {GENRES.map(g => <option value={g}>{g}</option>)}
            </select>
          </div>
          <div class="form-field">
            <label class="form-label" for="country">
              Pais <span class="form-label__required">*</span>
            </label>
            <input
              id="country" name="country" type="text"
              class="form-input" placeholder="ej. Honduras" required
            />
          </div>
        </div>

        <!-- Album title + Year -->
        <div class="form-row">
          <div class="form-field">
            <label class="form-label" for="album_title">Titulo del album</label>
            <input
              id="album_title" name="album_title" type="text"
              class="form-input" placeholder="ej. Inmaculada Concepcion"
            />
          </div>
          <div class="form-field">
            <label class="form-label" for="year">Ano de lanzamiento</label>
            <input
              id="year" name="year" type="number"
              class="form-input" placeholder="ej. 2024" min="1960" max="2030"
            />
          </div>
        </div>

        <!-- YouTube + Bandcamp -->
        <div class="form-row">
          <div class="form-field">
            <label class="form-label" for="youtube_url">YouTube URL</label>
            <input
              id="youtube_url" name="youtube_url" type="url"
              class="form-input" placeholder="https://youtu.be/..."
            />
          </div>
          <div class="form-field">
            <label class="form-label" for="bandcamp_url">Bandcamp URL</label>
            <input
              id="bandcamp_url" name="bandcamp_url" type="url"
              class="form-input" placeholder="https://band.bandcamp.com"
            />
          </div>
        </div>

        <!-- Description -->
        <div class="form-field">
          <label class="form-label" for="description">Descripcion</label>
          <textarea
            id="description" name="description"
            class="form-textarea" placeholder="Cuentanos sobre tu banda..."
            rows="4"
          ></textarea>
        </div>

        <!-- Toast -->
        <div class="form-toast" id="form-toast" role="alert"></div>

        <button type="submit" class="form-submit" id="submit-btn">
          Enviar banda
        </button>
      </form>
    </div>

    <!-- What happens next -->
    <section class="form-steps">
      <h2 class="form-steps__title">Que pasa despues?</h2>
      <div class="step-item">
        <span class="step-item__num">1</span>
        <div>
          <p class="step-item__title">Revisamos tu envio</p>
          <p class="step-item__desc">Escuchamos tu musica y verificamos la informacion.</p>
        </div>
      </div>
      <div class="step-item">
        <span class="step-item__num">2</span>
        <div>
          <p class="step-item__title">Te contactamos</p>
          <p class="step-item__desc">Si tu banda es seleccionada, te contactaremos para coordinar.</p>
        </div>
      </div>
      <div class="step-item">
        <span class="step-item__num">3</span>
        <div>
          <p class="step-item__title">Publicamos tu album</p>
          <p class="step-item__desc">Tu album aparece en el archivo con todos los detalles.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</body>
</html>

<script>
  // Wrapped in astro:page-load so the form handler re-binds after client-side
  // navigation (with ClientRouter this <script> does not re-execute on swap).
  // A per-form flag prevents double-binding.
  function initSubmitForm() {
    const API_BASE = import.meta.env.PUBLIC_API_BASE ?? 'https://app.danielbanariba.com';

    const form     = document.getElementById('submit-form') as HTMLFormElement | null;
    const btn      = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const toast    = document.getElementById('form-toast') as HTMLElement | null;
    const success  = document.getElementById('success-state') as HTMLElement | null;
    if (!form || !btn || !toast || !success || (form as any).__bound) return;
    (form as any).__bound = true;

    function showToast(msg: string, isError: boolean) {
      toast!.textContent = msg;
      toast!.className = `form-toast ${isError ? 'form-toast--error' : 'form-toast--success'}`;
      toast!.style.display = 'block';
    }

    // Per-field validation: mark the offending input and show a message next to
    // it (in Spanish). Errors are cleared on every submit attempt. No extra
    // hydration — this runs inside the form's existing submit handler.
    function clearFieldErrors() {
      form!.querySelectorAll('.form-input--error').forEach((el) => {
        el.classList.remove('form-input--error');
      });
      form!.querySelectorAll('.form-field__error').forEach((el) => el.remove());
    }

    function markFieldError(name: string, message: string) {
      const input = form!.querySelector(`[name="${name}"]`) as HTMLElement | null;
      if (!input) return;
      input.classList.add('form-input--error');
      const msg = document.createElement('span');
      msg.className = 'form-field__error';
      msg.textContent = message;
      input.insertAdjacentElement('afterend', msg);
      input.scrollIntoView({ block: 'center', behavior: 'smooth' });
      (input as HTMLInputElement).focus({ preventScroll: true });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      toast!.style.display = 'none';
      clearFieldErrors();

      const data = Object.fromEntries(new FormData(form!));

      // Client-side required check — mark the FIRST empty required field.
      const required = ['band_name', 'contact_email', 'genre', 'country'];
      for (const field of required) {
        if (!String(data[field] ?? '').trim()) {
          markFieldError(field, 'Este campo es obligatorio.');
          return;
        }
      }

      btn!.disabled = true;
      btn!.textContent = 'Enviando...';

      try {
        const res = await fetch(`${API_BASE}/api/metal-archive/submit`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const json = await res.json().catch(() => ({}));

        if (res.ok) {
          form!.style.display = 'none';
          success!.style.display = 'flex';
        } else {
          showToast(json.detail ?? 'Algo salio mal. Intentalo de nuevo.', true);
        }
      } catch {
        showToast('No se pudo conectar. Revisa tu conexion.', true);
      } finally {
        btn!.disabled = false;
        btn!.textContent = 'Enviar banda';
      }
    });
  }
  document.addEventListener('astro:page-load', initSubmitForm);
</script>
