---
// Metal Archive home — redesign (2026).
// Greeting + themed hero carousel (each slide tinted by its own album cover via
// vibrant.ts -> --slide-color) over the neutral base, then discovery sections.
import {
  getEditorPicks,
  getHiddenGems,
  getGenreShowcases,
  getCountryRotation,
  getLiveRecordings,
  getAllCountries,
  getAllYears,
  getAllAlbumIds,
  getTopBands,
  slugify,
} from '../../lib/db.js';
import { ClientRouter } from 'astro:transitions';
import { getAlbumColor } from '../../lib/vibrant.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Carousel from '../../components/Carousel.astro';
import AlbumCard from '../../components/AlbumCard.astro';
import '../../styles/global.css';

// ─── Data queries (all build-time) ───────────────────────────────────────────
const editorPicks     = getEditorPicks();
const hiddenGems      = getHiddenGems();
const genreShowcases  = getGenreShowcases(5);    // top 5 genres by album count
const countryRotation = getCountryRotation(6);   // 6 random countries + a sample album
const liveRecordings  = getLiveRecordings(12);   // Daniel's own live sets — own section
const allCountries    = getAllCountries();        // all distinct countries + counts
const allYears        = getAllYears();            // all distinct years + counts
const allAlbumIds     = getAllAlbumIds();         // for Surprise Me random pick
const topBands        = getTopBands(12);          // home "Bands" circular row

// ─── Hero carousel — featured albums (fallback: hidden gems), each tinted by
// its own cover's dominant color (cached by vibrant.ts -> zero runtime work). ──
const heroSource = (editorPicks.length ? editorPicks : hiddenGems).slice(0, 5);
const heroAlbums = await Promise.all(
  heroSource.map(async (album) => ({ album, color: await getAlbumColor(album.thumb) })),
);

// ─── Country flag lookup (same map as country/[country].astro) ────────────────
const COUNTRY_FLAGS: Record<string, string> = {
  "Alemania": "🇩🇪", "Arabia Saudita": "🇸🇦", "Argelia": "🇩🇿", "Argentina": "🇦🇷",
  "Armenia": "🇦🇲", "Australia": "🇦🇺", "Austria": "🇦🇹", "Azerbaiyan": "🇦🇿",
  "Bangladesh": "🇧🇩", "Belgica": "🇧🇪", "Bielorrusia": "🇧🇾", "Bolivia": "🇧🇴",
  "Bosnia": "🇧🇦", "Brasil": "🇧🇷", "Bulgaria": "🇧🇬", "Canada": "🇨🇦",
  "Chile": "🇨🇱", "China": "🇨🇳", "Colombia": "🇨🇴", "Corea del Sur": "🇰🇷",
  "Costa Rica": "🇨🇷", "Croacia": "🇭🇷", "Cuba": "🇨🇺", "Dinamarca": "🇩🇰",
  "Ecuador": "🇪🇨", "Egipto": "🇪🇬", "El Salvador": "🇸🇻", "Eslovaquia": "🇸🇰",
  "Eslovenia": "🇸🇮", "Espana": "🇪🇸", "Estados Unidos": "🇺🇸", "Estonia": "🇪🇪",
  "Filipinas": "🇵🇭", "Finlandia": "🇫🇮", "Francia": "🇫🇷", "Georgia": "🇬🇪",
  "Grecia": "🇬🇷", "Guatemala": "🇬🇹", "Honduras": "🇭🇳", "Hungria": "🇭🇺",
  "India": "🇮🇳", "Indonesia": "🇮🇩", "Irak": "🇮🇶", "Iran": "🇮🇷",
  "Irlanda": "🇮🇪", "Islandia": "🇮🇸", "Israel": "🇮🇱", "Italia": "🇮🇹",
  "Jamaica": "🇯🇲", "Japon": "🇯🇵", "Kazajistan": "🇰🇿", "Kenia": "🇰🇪",
  "Letonia": "🇱🇻", "Libano": "🇱🇧", "Lituania": "🇱🇹", "Luxemburgo": "🇱🇺",
  "Malasia": "🇲🇾", "Marruecos": "🇲🇦", "Mexico": "🇲🇽", "Mongolia": "🇲🇳",
  "Myanmar": "🇲🇲", "Nepal": "🇳🇵", "Nicaragua": "🇳🇮", "Nigeria": "🇳🇬",
  "Noruega": "🇳🇴", "Nueva Zelanda": "🇳🇿", "Paises Bajos": "🇳🇱", "Pakistan": "🇵🇰",
  "Panama": "🇵🇦", "Paraguay": "🇵🇾", "Peru": "🇵🇪", "Polonia": "🇵🇱",
  "Portugal": "🇵🇹", "Puerto Rico": "🇵🇷", "Reino Unido": "🇬🇧", "Republica Checa": "🇨🇿",
  "Republica Dominicana": "🇩🇴", "Rumania": "🇷🇴", "Rusia": "🇷🇺", "Serbia": "🇷🇸",
  "Singapur": "🇸🇬", "Sri Lanka": "🇱🇰", "Sudafrica": "🇿🇦", "Suecia": "🇸🇪",
  "Suiza": "🇨🇭", "Tailandia": "🇹🇭", "Taiwan": "🇹🇼", "Trinidad y Tobago": "🇹🇹",
  "Tunez": "🇹🇳", "Turquia": "🇹🇷", "Ucrania": "🇺🇦", "Uruguay": "🇺🇾",
  "Uzbekistan": "🇺🇿", "Venezuela": "🇻🇪", "Vietnam": "🇻🇳",
};

// JSON for Surprise Me — inline so no extra fetch is needed.
const albumIdsJson = JSON.stringify(allAlbumIds);
const ogImage = heroSource[0]?.thumb;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Metal Archive — Catálogo de metal underground</title>
    <meta name="description" content="El archivo definitivo del metal underground: death metal, brutal death, grindcore y más. Descubre bandas de todo el mundo." />
    <!-- OG / social meta -->
    <meta property="og:title" content="Metal Archive — Catálogo de metal underground" />
    <meta property="og:description" content="Catálogo de metal underground: death metal, brutal death, grindcore y más." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://xeroxunderground.com/metal-archive/" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Metal Archive" />
    <meta name="twitter:description" content="Archivo de metal underground." />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="canonical" href="https://xeroxunderground.com/metal-archive/" />
    <ClientRouter />
  </head>
  <body class="ma">
    <Navbar />

    <main>
      <div class="wrap">
        <!-- ─── Greeting (time-of-day set client-side; SSG can't know the
             visitor's local hour) ──────────────────────────────────────────── -->
        <header class="home-greeting">
          <div>
            <h1 class="home-greeting__hello" id="greeting">Hola</h1>
            <p class="home-greeting__sub">Catálogo de metal underground</p>
          </div>
          <div class="home-greeting__actions">
            <a class="home-greeting__icon" href="/metal-archive/newsletter" aria-label="Newsletter">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
            </a>
          </div>
        </header>

        <!-- ─── Hero carousel — each slide tinted by its own cover color ─────── -->
        {heroAlbums.length > 0 && (
          <section class="hero-carousel" aria-label="Álbumes destacados">
            <div class="hero-track" id="hero-track">
              {heroAlbums.map((h, i) => (
                <a
                  class="hero-slide"
                  style={`--slide-color: ${h.color};`}
                  href={`/metal-archive/album/${h.album.id}`}
                >
                  {h.album.thumb
                    ? <img class="hero-slide__bg" src={h.album.thumb} alt="" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
                    : <div class="hero-slide__bg" style="background: var(--content);" aria-hidden="true"></div>
                  }
                  <div class="hero-slide__inner">
                    <span class="hero-slide__eyebrow">✦ Destacado</span>
                    <span class="hero-slide__band">{h.album.band_name}</span>
                    <span class="hero-slide__album">{h.album.album_title}</span>
                    <span class="hero-slide__meta">
                      {[h.album.genre, h.album.country, h.album.year].filter(Boolean).join(' · ')}
                    </span>
                    <span class="hero-slide__cta">
                      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M7 5v14l12-7z"/></svg>
                      Reproducir
                    </span>
                  </div>
                </a>
              ))}
            </div>
            {heroAlbums.length > 1 && (
              <div class="hero-dots" id="hero-dots">
                {heroAlbums.map((_, i) => (
                  <button class="hero-dot" type="button" aria-label={`Ir al destacado ${i + 1}`}></button>
                ))}
              </div>
            )}
          </section>
        )}
      </div>

      <div class="wrap home-sections">
        <!-- Search — discovery entry point; submits to browse (?q=) ─────────── -->
        <section class="home-search">
          <form class="home-search__form" action="/metal-archive/browse" method="get" role="search">
            <svg class="home-search__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input
              class="home-search__input"
              type="search"
              name="q"
              placeholder="Busca bandas, álbumes, géneros..."
              aria-label="Busca bandas, álbumes, géneros"
              autocomplete="off"
            />
            <button class="home-search__btn" type="submit">Buscar</button>
          </form>
        </section>

        <!-- Bands — circular avatars (representative cover as the avatar) ──────── -->
        {topBands.length > 0 && (
          <section class="carousel-deferred">
            <div class="section-header">
              <h3>Bandas</h3>
              <a href="/metal-archive/browse" class="section-header__link">Ver todo →</a>
            </div>
            <div class="bands-row">
              {topBands.map((b) => (
                <a class="band-avatar" href={`/metal-archive/band/${slugify(b.band_name)}`}>
                  <span class="band-avatar__img-wrap">
                    {b.thumb
                      ? <img class="band-avatar__img" src={b.thumb} alt={b.band_name} loading="lazy" decoding="async" />
                      : <span class="band-avatar__img band-avatar__img--empty" aria-hidden="true"></span>
                    }
                  </span>
                  <span class="band-avatar__name">{b.band_name}</span>
                  <span class="band-avatar__count">{b.count} {b.count === 1 ? 'álbum' : 'álbumes'}</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Hidden Gems — horizontal scroll row ─────────────────────────────── -->
        {hiddenGems.length > 0 && (
          <Carousel
            title="Joyas ocultas"
            albums={hiddenGems}
            href="/metal-archive/browse"
            layout="scroll"
            deferred={false}
          />
        )}

        <!-- Genre showcases — one cover row per top genre ──────────────────── -->
        {genreShowcases.map((showcase) => (
          <Carousel
            title={showcase.genre}
            albums={showcase.albums}
            href={`/metal-archive/genre/${slugify(showcase.genre)}`}
            layout="scroll"
            deferred={true}
          />
        ))}

        <!-- Country rotation "Explore {country}" ───────────────────────────── -->
        {countryRotation.length > 0 && (
          <Carousel
            title={`Explora ${countryRotation[0]?.country ?? 'el mundo'}`}
            albums={countryRotation.map((c) => c.album)}
            layout="scroll"
            deferred={true}
          />
        )}

        <!-- Live Recordings — Daniel's OWN live sets, visually separate ─────── -->
        {liveRecordings.length > 0 && (
          <section class="section carousel-deferred live-section">
            <div class="section-header">
              <div class="live-section__heading">
                <h3>Grabaciones en vivo</h3>
                <span class="live-section__badge">Sets en vivo</span>
              </div>
            </div>
            <p class="live-section__note">
              Grabaciones en vivo personales — separadas del catálogo oficial de álbumes.
            </p>
            <div class="carousel-row">
              {liveRecordings.map((a) => <AlbumCard album={a} loading="lazy" livePlaceholder={true} />)}
            </div>
          </section>
        )}

        <!-- Browse-by sections ─────────────────────────────────────────────── -->
        <hr class="home-divider" />

        {allCountries.length > 0 && (
          <section class="carousel-deferred home-browse-by">
            <div class="section-header">
              <h3>Explora por país</h3>
              <a href="/metal-archive/browse" class="section-header__link">Ver todo →</a>
            </div>
            <div class="country-grid">
              {allCountries.map((facet) => (
                <a
                  class="facet-card"
                  href={`/metal-archive/country/${slugify(facet.value)}`}
                  title={`${facet.count} ${facet.count === 1 ? 'álbum' : 'álbumes'} de ${facet.value}`}
                >
                  {COUNTRY_FLAGS[facet.value] && (
                    <span class="facet-card__flag" aria-hidden="true">
                      {COUNTRY_FLAGS[facet.value]}
                    </span>
                  )}
                  <span class="facet-card__name">{facet.value}</span>
                  <span class="facet-card__count">
                    {facet.count} {facet.count === 1 ? 'álbum' : 'álbumes'}
                  </span>
                </a>
              ))}
            </div>
          </section>
        )}

        {allYears.length > 0 && (
          <section class="carousel-deferred home-browse-by">
            <div class="section-header">
              <h3>Explora por año</h3>
              <a href="/metal-archive/browse" class="section-header__link">Ver todo →</a>
            </div>
            <div class="year-grid">
              {allYears.map((facet) => (
                <a
                  class="facet-card"
                  href={`/metal-archive/year/${facet.value}`}
                  title={`${facet.count} ${facet.count === 1 ? 'álbum' : 'álbumes'} de ${facet.value}`}
                >
                  <span class="facet-card__name">{facet.value}</span>
                  <span class="facet-card__count">
                    {facet.count} {facet.count === 1 ? 'álbum' : 'álbumes'}
                  </span>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Surprise Me ────────────────────────────────────────────────────── -->
        <div class="home-cta-row">
          <button id="btn-random" class="btn-sorprendeme" type="button">
            Sorpréndeme
          </button>
        </div>

        <script define:vars={{ albumIdsJson }} data-astro-rerun>
          // define:vars forces this script inline (non-bundled), so it would NOT
          // run when ClientRouter swaps the home page in from another page.
          // data-astro-rerun makes it re-execute after every view transition that
          // lands on a page containing it — so it runs on first load AND whenever
          // we navigate (back) to home. The __bound guard avoids duplicate
          // listeners; window.__albumIds is (re)published for the navbar Surprise Me.
          (function () {
            var ids = JSON.parse(albumIdsJson);
            window.__albumIds = ids;
            var btn = document.getElementById('btn-random');
            if (!btn || btn.__bound) return;
            btn.__bound = true;
            btn.addEventListener('click', function () {
              if (!ids.length) return;
              var id = ids[Math.floor(Math.random() * ids.length)];
              window.location.href = '/metal-archive/album/' + id;
            });
          })();
        </script>

        <!-- YouTube CTA ────────────────────────────────────────────────────── -->
        <div class="home-cta-row home-cta-row--tight">
          <a
            class="btn-youtube"
            href="https://www.youtube.com/channel/UCa5U18nMgHUsqg-zsE1779Q?sub_confirmation=1"
            target="_blank"
            rel="noopener noreferrer"
          >
            Suscríbete al canal
          </a>
        </div>
      </div><!-- /.wrap -->
    </main>

    <Footer />

    <!-- Time-of-day greeting + hero carousel dot sync (vanilla, no framework) -->
    <script>
      // With ClientRouter this <script> does not re-execute on navigation, and
      // the home markup (greeting, carousel) is fresh after every swap — so we
      // run the whole init on astro:page-load (fires on first load too). A
      // per-element guard avoids re-binding dot clicks / re-observing slides if
      // the same DOM is revisited without a swap.
      (function () {
        function initHome() {
          var g = document.getElementById('greeting');
          if (g) {
            var h = new Date().getHours();
            g.textContent =
              h < 6 ? 'Buenas noches' : h < 12 ? 'Buenos días' : h < 19 ? 'Buenas tardes' : 'Buenas noches';
          }

          var track = document.getElementById('hero-track');
          var dotsWrap = document.getElementById('hero-dots');
          if (!track || !dotsWrap || (track as any).__bound) return;
          (track as any).__bound = true;
          var slides = Array.prototype.slice.call(track.querySelectorAll('.hero-slide'));
          var dots = Array.prototype.slice.call(dotsWrap.querySelectorAll('.hero-dot'));
          if (!slides.length || !dots.length) return;

          function setActive(i) {
            for (var j = 0; j < dots.length; j++) dots[j].classList.toggle('is-active', j === i);
          }
          setActive(0);

          dots.forEach(function (d, i) {
            d.addEventListener('click', function () {
              slides[i].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
            });
          });

          if ('IntersectionObserver' in window) {
            var io = new IntersectionObserver(
              function (entries) {
                entries.forEach(function (e) {
                  if (e.isIntersecting) {
                    var idx = slides.indexOf(e.target);
                    if (idx >= 0) setActive(idx);
                  }
                });
              },
              { root: track, threshold: 0.6 },
            );
            slides.forEach(function (s) { io.observe(s); });
          }
        }
        document.addEventListener('astro:page-load', initHome);
      })();
    </script>
  </body>
</html>
