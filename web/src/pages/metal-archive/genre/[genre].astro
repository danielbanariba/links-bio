---
// Slug strategy: genres contain spaces and slashes (e.g. "Brutal Death Metal/Goregrind").
// A raw "/" in a path param would create a nested route, so we slugify:
//   "Brutal Death Metal/Goregrind" -> "brutal-death-metal-goregrind"
// The real genre value travels as a prop so we can query without lossy decoding.
// Pattern: getStaticPaths returns { params: { genre: slug }, props: { realGenre } }
// slugify is imported from db.ts (the single source of truth, shared with the
// pages that link here). Imports are available in the prerender chunk; the old
// inline copy is gone so paths and links can never drift apart.
import { ClientRouter } from 'astro:transitions';
import { getAllGenres, getAlbumsByGenre, slugify } from '../../../lib/db.js';
import { getAlbumColor } from '../../../lib/vibrant.js';
import AlbumCard from '../../../components/AlbumCard.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import '../../../styles/global.css';

export function getStaticPaths() {
  const genres = getAllGenres();
  return genres.map((facet) => ({
    params: { genre: slugify(facet.value) },
    props: { realGenre: facet.value },
  }));
}

interface Props {
  realGenre: string;
}

const { realGenre } = Astro.props;
// NOT_LIVE applied inside getAlbumsByGenre; derive the count from the same list
// so the header number and the grid always agree (comparable to Browse).
const albums = getAlbumsByGenre(realGenre);
const count = albums.length;

// P2 mini-hero color: inherit --album-color from the representative (newest)
// cover via the cached vibrant extractor — reads .vibrant-cache.json, never a
// cold build. albums is already ordered upload_date DESC (discovery order), and
// Card.thumb is already the mqdefault URL the cache is keyed by.
const repCover = albums[0]?.thumb ?? '';
const genreColor = repCover ? await getAlbumColor(repCover) : '#dda15e';

// Chain to Browse with this genre pre-applied. The Search island restores its
// dropdown from the exact value (e.genre === genre), so the URL must carry the
// REAL genre, not the slug.
const browseHref = `/metal-archive/browse?genre=${encodeURIComponent(realGenre)}`;
---

<!doctype html>
<html lang="es" style={`--album-color: ${genreColor};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{realGenre} — Metal Archive</title>
    <meta name="description" content={`${count} ${realGenre} ${count === 1 ? 'album' : 'albumes'} en el Metal Archive.`} />
    <ClientRouter />
  </head>
  <body>
    <Navbar />

    <main class="wrap" style="padding-top: 2rem;">
      <header class="facet-hero">
        <h1 class="facet-hero__title">{realGenre}</h1>
        <p class="facet-hero__count">
          {count} {count === 1 ? 'album' : 'albumes'}
        </p>
        {albums.length > 0 && (
          <a class="facet-refine" href={browseHref}>Refinar en Explorar →</a>
        )}
      </header>

      {albums.length > 0
        ? <div class="album-grid">
            {albums.map((album) => <AlbumCard album={album} />)}
          </div>
        : <p style="color: var(--text-footer);">No hay albumes en este genero.</p>
      }
    </main>

    <Footer />
  </body>
</html>
