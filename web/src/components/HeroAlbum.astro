---
// HeroAlbum: full-bleed featured album header, gallery cover-first.
// A large square cover anchors one side; minimal display-type meta the other.
// --album-color baked inline at build time via vibrant.ts drives the gradient.
import type { Card } from '../lib/types.js';

interface Props {
  album: Card & { description?: string | null; youtube_url?: string | null };
  albumColor?: string;
}

const { album, albumColor = 'var(--secondary)' } = Astro.props;
const href = `/metal-archive/album/${album.id}`;
---

<section
  class="hero"
  style={`background: linear-gradient(160deg, ${albumColor}b3 0%, ${albumColor}40 40%, var(--bg) 100%);`}
>
  <!-- Noise texture overlay: 8% opacity, mix-blend-mode overlay -->
  <div class="noise-overlay" aria-hidden="true"></div>

  <div class="hero__inner wrap">
    <a class="hero__art" href={href} aria-label={`${album.band_name} — ${album.album_title}`}>
      {album.thumb
        ? <img
            class="hero__cover"
            src={album.thumb}
            alt={`${album.band_name} — ${album.album_title}`}
            loading="eager"
            decoding="async"
            width="520"
            height="520"
          />
        : <div class="hero__cover hero__cover--empty" aria-hidden="true" />
      }
      <span class="hero__play" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor">
          <path d="M8 5v14l11-7z" />
        </svg>
      </span>
    </a>
    <div class="hero__meta">
      <div class="hero__release-type">Featured</div>
      <h1 class="hero__band">{album.band_name}</h1>
      <div class="hero__album">{album.album_title}</div>
      <div class="hero__meta-row">
        {[album.genre, album.year, album.country].filter(Boolean).join(' · ')}
      </div>
      <a class="hero__cta" href={href}>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M8 5v14l11-7z" />
        </svg>
        View Album
      </a>
    </div>
  </div>
</section>
